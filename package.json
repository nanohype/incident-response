{
  "name": "incident-response",
  "version": "0.1.0",
  "description": "Ceremonial incident commander assistant — P1 war room assembly, status cadence, status page approval gate, postmortem draft",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.eslint.json --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts' '*.json'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts' '*.json'",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern='test/unit' --forceExit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.integration.cjs --forceExit",
    "test:integration:docker": "docker run --rm -d --name marshal-ddb-local -p 8000:8000 amazon/dynamodb-local && npm run test:integration; STATUS=$?; docker rm -f marshal-ddb-local > /dev/null 2>&1; exit $STATUS",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:webhook": "node dist/bin/webhook-server.js",
    "chart:lint": "helm lint chart",
    "chart:template:staging": "helm template marshal chart -f chart/values-staging.yaml",
    "chart:template:production": "helm template marshal chart -f chart/values-production.yaml",
    "seed:staging": "bash scripts/seed-secrets.sh --env staging",
    "seed:production": "bash scripts/seed-secrets.sh --env production",
    "seed:staging:dry": "bash scripts/seed-secrets.sh --env staging --dry-run",
    "seed:production:dry": "bash scripts/seed-secrets.sh --env production --dry-run",
    "drill:staging": "bash scripts/fire-drill.sh --env staging --state firing",
    "drill:production": "bash scripts/fire-drill.sh --env production --state firing",
    "drill:join:staging": "bash scripts/join-drill-channel.sh --env staging",
    "drill:join:production": "bash scripts/join-drill-channel.sh --env production",
    "observe:staging": "bash scripts/observe-incident.sh --env staging --latest",
    "observe:production": "bash scripts/observe-incident.sh --env production --latest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-scheduler": "^3.750.0",
    "@aws-sdk/client-secrets-manager": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@aws-sdk/util-dynamodb": "^3.750.0",
    "@linear/sdk": "^30.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.0.0",
    "node-fetch": "^3.3.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@smithy/node-http-handler": "^4.0.0",
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.0.0",
    "aws-sdk-client-mock": "^4.0.0",
    "aws-sdk-client-mock-jest": "^4.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "prettier": "3.8.3",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0"
  }
}

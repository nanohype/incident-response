{
  "name": "incident-response",
  "version": "0.1.0",
  "description": "Ceremonial incident commander assistant — P1 war room assembly, status cadence, status page approval gate, postmortem draft",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:docker": "docker run --rm -d --name incident-response-ddb-local -p 8000:8000 amazon/dynamodb-local && npm run test:integration; STATUS=$?; docker rm -f incident-response-ddb-local > /dev/null 2>&1; exit $STATUS",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "start:webhook": "node dist/bin/webhook-server.js",
    "sync:vendored": "node scripts/sync-vendored.mjs",
    "sync:vendored:check": "node scripts/sync-vendored.mjs --check",
    "chart:lint": "helm lint chart",
    "chart:template:staging": "helm template incident-response chart -f chart/values-staging.yaml",
    "chart:template:production": "helm template incident-response chart -f chart/values-production.yaml",
    "seed:staging": "bash scripts/seed-secrets.sh --env staging",
    "seed:production": "bash scripts/seed-secrets.sh --env production",
    "seed:staging:dry": "bash scripts/seed-secrets.sh --env staging --dry-run",
    "seed:production:dry": "bash scripts/seed-secrets.sh --env production --dry-run",
    "drill:staging": "bash scripts/fire-drill.sh --env staging --state firing",
    "drill:production": "bash scripts/fire-drill.sh --env production --state firing",
    "drill:join:staging": "bash scripts/join-drill-channel.sh --env staging",
    "drill:join:production": "bash scripts/join-drill-channel.sh --env production",
    "observe:staging": "bash scripts/observe-incident.sh --env staging --latest",
    "observe:production": "bash scripts/observe-incident.sh --env production --latest"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-scheduler": "^3.750.0",
    "@aws-sdk/client-secrets-manager": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@aws-sdk/util-dynamodb": "^3.750.0",
    "@linear/sdk": "^88.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@slack/web-api": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@smithy/node-http-handler": "^4.0.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "aws-sdk-client-mock": "^4.0.0",
    "aws-sdk-client-mock-vitest": "^7.1.0",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@grpc/grpc-js": "^1.14.4",
    "form-data": "^4.0.6",
    "protobufjs": "^7.6.5",
    "ws": "^8.21.0",
    "js-yaml": "^4.2.0",
    "qs": "^6.15.2",
    "@babel/core": "^7.29.6",
    "axios": "^1.18.1",
    "body-parser": "^2.3.0",
    "brace-expansion": "^2.1.2",
    "@opentelemetry/propagator-jaeger": "^2.9.0",
    "@hono/node-server": "^2.0.11"
  }
}

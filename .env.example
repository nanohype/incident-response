# IncidentResponse — environment configuration template.
# Copy to `.env` for local dev. In-cluster, these arrive as pod env: secret values are
# projected from AWS Secrets Manager by the ExternalSecret and consumed via `envFrom`;
# the rest come from the chart's `env` / `tenantInfra` values.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-west-2

# ── Slack (signed HTTP) ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-replace-with-bot-token
SLACK_SIGNING_SECRET=replace-with-signing-secret

# ── Grafana OnCall (webhook source + escalation chain API) ───────────────────
GRAFANA_ONCALL_TOKEN=replace-with-grafana-oncall-api-token
GRAFANA_ONCALL_BASE_URL=https://oncall-prod-us-central-0.grafana.net

# ── Grafana Cloud (read-only Mimir/Loki/Tempo for context snapshot) ──────────
GRAFANA_CLOUD_TOKEN=replace-with-grafana-cloud-api-token
GRAFANA_CLOUD_ORG_ID=replace-with-org-id
GRAFANA_CLOUD_BASE_URL=https://prometheus-prod-01-prod-us-east-0.grafana.net

# ── Statuspage.io (customer-facing status; approval-gated) ───────────────────
STATUSPAGE_API_KEY=replace-with-statuspage-api-key
STATUSPAGE_PAGE_ID=replace-with-page-id

# ── Linear (postmortem draft destination) ────────────────────────────────────
LINEAR_API_KEY=replace-with-linear-api-key
LINEAR_PROJECT_ID=replace-with-linear-project-id
LINEAR_TEAM_ID=replace-with-linear-team-id

# ── WorkOS Directory Sync (responder resolution by group) ────────────────────
WORKOS_API_KEY=sk_live_replace-with-workos-api-key
# The directory the group lookups are scoped to (WorkOS dashboard → Directory Sync).
WORKOS_DIRECTORY_ID=directory_replace-with-workos-directory-id
# Optional: JSON map from grafana team_id → WorkOS directory_group_id. Example:
# WORKOS_TEAM_GROUP_MAP={"team-platform":"directory_group_01...","team-data":"directory_group_01..."}

# ── GitHub (CODEOWNERS + recent commits for postmortem deploy timeline) ──────
GITHUB_TOKEN=replace-with-github-pat-or-app-token
GITHUB_ORG_SLUG=your-org
# Comma-separated list of repos the postmortem should query for recent deploys.
GITHUB_REPO_NAMES=svc-api,svc-worker,svc-frontend

# ── DynamoDB tables (chart tenantInfra.* ← landing-zone outputs) ─────────────
# Staging values shown for local dev; production swaps the env segment.
INCIDENTS_TABLE_NAME=incident-response-staging-incidents
AUDIT_TABLE_NAME=incident-response-staging-audit

# ── SQS queues (chart tenantInfra.* ← landing-zone outputs) ──────────────────
INCIDENT_EVENTS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/incident-response-staging-incident-events.fifo
NUDGE_EVENTS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/incident-response-staging-nudge-events
SLA_CHECK_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/000000000000/incident-response-staging-sla-check-events

# ── EventBridge Scheduler (chart tenantInfra.* ← landing-zone outputs) ───────
SCHEDULER_ROLE_ARN=arn:aws:iam::000000000000:role/IncidentResponseStaging-SchedulerRole
# Env-scoped scheduler group so staging + production nudge rules don't collide.
# Staging: incident-response-staging | Production: incident-response-production
SCHEDULER_GROUP_NAME=incident-response-staging

# ── HMAC webhook secret ARN (chart externalSecret.hmacSecret) ────────────────
GRAFANA_ONCALL_HMAC_SECRET_ARN=arn:aws:secretsmanager:us-west-2:000000000000:secret:incident-response/staging/grafana/oncall-webhook-hmac

# ── Logical environment (chart env.*) ────────────────────────────────────────
# One of: staging | production. Drives OTel deployment.environment + log labels.
DEPLOYMENT_ENV=staging

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# ── Bedrock model IDs (optional — defaults in src/config/) ───────────────────
# Override to pin a dated snapshot or a cross-region inference profile.
# BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-6
# BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

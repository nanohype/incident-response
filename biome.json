{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "extends": ["./biome.base.json"],
  "linter": {
    "rules": {
      "suspicious": {
        "noConsole": "error"
      },
      "nursery": {
        "noFloatingPromises": "error"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!package-lock.json",
      "!*.md",
      "!chart/templates",
      "!chart/dashboards",
      "!src/vendor",
      "!scripts/sync-vendored.mjs"
    ]
  },
  "overrides": [
    {
      "includes": ["scripts/**/*.mjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
